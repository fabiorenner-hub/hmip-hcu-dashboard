  "author": "Fabio Renner",
  "license": "Apache-2.0",
  "homepage": "https://github.com/fabiorenner-hub/hmip-hcu-dashboard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabiorenner-hub/hmip-hcu-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/fabiorenner-hub/hmip-hcu-dashboard/issues"
  },
  "keywords": [
    "homematic",
    "hmip",
    "hcu",
    "dashboard",
    "smart-home"
  ],
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --enable-source-maps src/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
