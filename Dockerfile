# HCU plugin image. Must be linux/arm64 and carry the metadata label.
FROM --platform=linux/arm64 ghcr.io/homematicip/alpine-node-simple:0.0.1

WORKDIR /app

COPY package.json .npmrc ./
COPY package-lock.jso[n] ./
RUN npm install --omit=dev --no-audit --no-fund --loglevel=error

COPY src ./src
COPY public ./public

# /data is created by the HCU for installed plugins and persists across
# container updates. Editable config lives there.
VOLUME ["/data"]

# Dashboard HTTP port. The HCU maps container ports 1:1 to the host, so the
# dashboard will be reachable at http://hcu1-XXXX.local:8080 on the LAN.
EXPOSE 8080

ENV NODE_ENV=production \
    HMIP_PLUGIN_ID=de.homematicip.plugin.dashboard \
    LOG_LEVEL=info

ENTRYPOINT ["node", "src/index.js"]

LABEL de.eq3.hmip.plugin.metadata="{\"pluginId\":\"de.homematicip.plugin.dashboard\",\"issuer\":\"Fabio Renner\",\"version\":\"1.1.2\",\"hcuMinVersion\":\"1.4.7\",\"scope\":\"LOCAL\",\"friendlyName\":{\"de\":\"Smart Home Dashboard\",\"en\":\"Smart Home Dashboard\"},\"description\":{\"de\":\"Lokale Weboberflaeche fuer die Homematic IP Anlage mit Live-Uebersicht ueber Fenster, Klima, Licht, Steckdosen, Rolllaeden, Sicherheit und Wartung.\",\"en\":\"Locally hosted web dashboard for the Homematic IP system, with a live overview of windows, climate, lights, sockets, shutters, security and maintenance.\"},\"settings\":[],\"changelog\":\"1.1.2 - Docs polish: README rewritten cleanly in UTF-8 to fix mojibake on the GitHub repo page.\n1.1.1 - Plugin icon shown in HCUweb (image label), cleaner description.\n1.1.0 - Plugin icon, GitHub link and PayPal donation hint added to plugin metadata, README and HCU description.\\n1.0.0 - Initial public release.\",\"logsEnabled\":true,\"image\":\"\"}"